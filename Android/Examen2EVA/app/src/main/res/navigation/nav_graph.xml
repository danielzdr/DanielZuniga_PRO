<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/fragmentLogin">
    <fragment
        tools:layout="@layout/login_fragment"
        android:id="@+id/fragmentLogin"
        android:name="com.example.examen.ui.fragment.FragmentLogin"
        android:label="FragmentLogin" >
        <action
            android:id="@+id/action_fragmentLogin_to_fragmentMain"
            app:destination="@id/fragmentMain" />
        <argument
            android:name="email"
            app:argType="string" />
    </fragment>
    <fragment
        tools:layout="@layout/main_fragment"
        android:id="@+id/fragmentMain"
        android:name="com.example.examen.ui.fragment.FragmentMain"
        android:label="FragmentMain" >
        <action
            android:id="@+id/action_fragmentMain_to_fragmentFav"
            app:destination="@id/fragmentFav" />
        <argument
            android:name="email"
            app:argType="string" />
    </fragment>
    <fragment
        tools:layout="@layout/fav_fragment"
        android:id="@+id/fragmentFav"
        android:name="com.example.examen.ui.fragment.FragmentFav"
        android:label="FragmentFav" />
</navigation>