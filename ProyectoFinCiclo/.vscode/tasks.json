{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Activar venv (PowerShell)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoExit",
				"-Command",
				"Set-ExecutionPolicy -Scope Process -ExecutionPolicy Bypass -Force; & .\\.venv\\Scripts\\Activate.ps1"
			],
			"isBackground": false,
			"group": "none"
		}
	]
}